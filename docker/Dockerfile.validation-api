FROM python:3.11-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    APP_HOME=/app

WORKDIR ${APP_HOME}

COPY pyproject.toml README.md ./
COPY nexis ./nexis

RUN pip install --upgrade pip \
    && pip install .

EXPOSE 8080

CMD ["python", "-m", "uvicorn", "nexis.api.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "8080"]

