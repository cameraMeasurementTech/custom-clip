NEXIS_NETUID=70
NEXIS_LOG_LEVEL=INFO
BT_NETWORK=finney
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=~/.bittensor/wallets

# Cloudflare R2 storage
R2_ACCOUNT_ID=
R2_REGION=auto

# Miner required
# Bucket is derived automatically from lowercase miner hotkey.
R2_READ_ACCESS_KEY=
R2_READ_SECRET_KEY=
R2_WRITE_ACCESS_KEY=
R2_WRITE_SECRET_KEY=

# Miner pipeline
NEXIS_SOURCES_FILE=sources.txt
NEXIS_WORKDIR=.nexis
# Continuous mode: one clip per poll into miner_pending_records.jsonl; upload deduped batch every N blocks
# NEXIS_MINER_CONTINUOUS_PACK_MODE=false
# Upload pending pack at most once per this many blocks (default 100). R2 folder interval_id still uses INTERVAL_LENGTH_BLOCKS in protocol.
# NEXIS_MINER_UPLOAD_CADENCE_BLOCKS=100
# After each successful interval upload, delete the R2 folder from N uploads ago (default 2)
# NEXIS_MINER_R2_PRUNE_OLD_PREFIX=true
# NEXIS_MINER_R2_PRUNE_UPLOADS_AGO=2
# If {interval_id}/manifest.json already exists on R2, sleep this many seconds and retry (default 1200 = 20m; 0 = off)
# NEXIS_MINER_UPLOAD_MANIFEST_BUSY_WAIT_SEC=1200
# When building miner_pending_records.jsonl: validator hard checks + optional local 720p/sha on each new row (default on)
# NEXIS_MINER_PREPARE_VALIDATE_BEFORE_SAVE=true
# NEXIS_MINER_PREPARE_ASSET_VERIFY=true
# Before R2 upload: optional second pass (default off if prepare validation is on)
# NEXIS_MINER_PREFLIGHT_BEFORE_UPLOAD=false
# Optional LLM during prepare and/or upload preflight (extra API cost)
# NEXIS_MINER_PREFLIGHT_SEMANTIC=false
# NEXIS_MINER_PREFLIGHT_CATEGORY=false
#
# Split prepare / upload (no chain poll):
#   nexis mine-prepare --workdir /data/pool --sources urls.txt --workers 3 --thread-keys-file keys.txt
#   (urls.txt lines are removed top-down as each worker claims a URL; POSIX lock on urls.txt.queue.lock)
#   nexis mine-upload --workdir /data/pool --interval-id 12345600
#   (--keep-local skips deleting clips/frames/out/{interval_id}/ after upload)
NEXIS_BLOCK_POLL_SEC=6
NEXIS_DATASET_CATEGORY=nature_landscape_scenery
TARGET_RESOLUTION=720
NEXIS_VALIDATOR_BLACKLIST_FILE=validator_blacklist_hotkeys.txt

# LLM provider keys (OpenAI preferred when both are set)
OPENAI_API_KEY=
# Second key (comma/newline allowed); merged with OPENAI_API_KEY, deduplicated
# NEXIS_OPENAI_API_KEYS=sk-...
# 3 requests/minute per key => ~6/min with two keys (staggered; 429 rotates to other key)
NEXIS_CAPTION_OPENAI_RPM_PER_KEY=3
GEMINI_API_KEY=
NEXIS_CAPTION_MODEL=gpt-4o
NEXIS_CAPTION_TIMEOUT_SEC=30
NEXIS_VALIDATOR_SEMANTIC_CHECK_ENABLED=true
NEXIS_VALIDATOR_SEMANTIC_MODEL=gpt-4o
NEXIS_VALIDATOR_SEMANTIC_TIMEOUT_SEC=20
NEXIS_VALIDATOR_SEMANTIC_MAX_SAMPLES=8
NEXIS_VALIDATOR_SEMANTIC_MAX_TRANSIENT_RETRIES=5
NEXIS_VALIDATOR_SEMANTIC_RETRY_BASE_SLEEP_SEC=2
NEXIS_VALIDATOR_SEMANTIC_RETRY_SLEEP_CAP_SEC=120
NEXIS_VALIDATOR_CATEGORY_CHECK_ENABLED=true
NEXIS_VALIDATOR_CATEGORY_MODEL=gpt-4o
NEXIS_VALIDATOR_CATEGORY_TIMEOUT_SEC=20
NEXIS_VALIDATOR_CATEGORY_MAX_SAMPLES=8

# Validator required
NEXIS_RECORD_INFO_BUCKET=nexis-record-info
NEXIS_RECORD_INFO_ACCOUNT_ID=
NEXIS_RECORD_INFO_READ_ACCESS_KEY=
NEXIS_RECORD_INFO_READ_SECRET_KEY=
NEXIS_RECORD_INFO_OBJECT_KEY=record_info.json
NEXIS_VALIDATION_API_URL=https://api.nexisgen.ai/v1/validation-results
NEXIS_VALIDATION_API_TIMEOUT_SEC=10

# Owner requred
NEXIS_OWNER_VALIDATOR_HOTKEY=5EJGfSvRcEGVQtqDuU7YYwuZRHmaktf6JEZDeFPyeXksiHrm
NEXIS_OWNER_DB_BUCKET=nexis-dataset
NEXIS_OWNER_DB_ACCOUNT_ID=
NEXIS_OWNER_DB_READ_ACCESS_KEY=
NEXIS_OWNER_DB_READ_SECRET_KEY=
NEXIS_OWNER_DB_WRITE_ACCESS_KEY=
NEXIS_OWNER_DB_WRITE_SECRET_KEY=
NEXIS_RECORD_INFO_WRITE_ACCESS_KEY=
NEXIS_RECORD_INFO_WRITE_SECRET_KEY=
